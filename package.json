{
  "name": "trading-exchange-simulator",
  "version": "0.1.0",
  "private": true,
  "description": "Live paper-trading exchange with an in-memory price-time priority matching engine",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/src/server/index.js",
    "bench": "tsc && node dist/bench/engine-bench.js",
    "bench:http": "tsc && node dist/bench/http-bench.js"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  }
}
